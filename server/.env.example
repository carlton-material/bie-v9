# BIE Signal Server Configuration
# Copy this file to .env and fill in your API keys

# Finnhub API key (free tier: 60 calls/min)
# Get yours at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Server port (default: 3847)
PORT=3847

# Polling intervals (in minutes)
RSS_POLL_INTERVAL=15
STOCK_POLL_INTERVAL=30

# Max signals to keep in memory
MAX_SIGNALS=1000
